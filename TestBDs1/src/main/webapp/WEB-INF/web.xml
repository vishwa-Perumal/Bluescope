<!DOCTYPE web-app PUBLIC
 "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
 "http://java.sun.com/dtd/web-app_2_3.dtd" >

<web-app>
  <display-name>Archetype Created Web Application</display-name>
    <servlet>
        <servlet-name>TestBDser1</servlet-name>
        <servlet-class>com.TestDBs1.TestBDser</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>TestBDser2</servlet-name>
        <servlet-class>com.TestDBs1.TestBDser</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>TestBDser3</servlet-name>
        <servlet-class>com.TestDBs1.TestBDser</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>TestBDser4</servlet-name>
        <servlet-class>com.TestDBs1.TestBDser</servlet-class>
    </servlet>

    <!-- ===== SERVLET MAPPINGS AFTER ===== -->

    <servlet-mapping>
        <servlet-name>TestBDser1</servlet-name>
        <url-pattern>/getuser</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>TestBDser2</servlet-name>
        <url-pattern>/postuser</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>TestBDser3</servlet-name>
        <url-pattern>/updateuser</url-pattern>
    </servlet-mapping>
    
     <servlet-mapping>
        <servlet-name>TestBDser4</servlet-name>
        <url-pattern>/deleteuser</url-pattern>
    </servlet-mapping>
</web-app>
